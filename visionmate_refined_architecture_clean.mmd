flowchart LR
  %% Left: Users
  subgraph USERS[Users]
    direction TB
    VIU[Visually Impaired User]
    GUARD[Guardian]
  end

  %% Center: App container
  subgraph APP[VisionMate App]
    direction TB
    subgraph ONDEV[On-device AI & Storage]
      Camera[Camera]
      Obj[Object Detector\n(YOLOv8n-int8)]
      Face[MobileFaceNet\n(embeddings)]
      SQLite[SQLite Embeddings\n(local cache)]
      Main[Main Logic\n(alerting, safety, routing)]
    end

    subgraph UI[User Interfaces]
      UMain[User Main UI]
      GInterface[Guardian Interface]
      FavScreen[Favorite Destinations]
    end

    subgraph SERVICES[App Services]
      LocationSvc[LocationService]
      Tracker[UserLocationTracker]
      SyncSvc[Firebase Sync]
      Nav[Navigation / Route]
    end
  end

  %% Right: Cloud and Hardware
  subgraph CLOUD[Cloud Services]
    Auth[Firebase Auth]
    Firestore[Firestore (users, registered_faces, sosAlert)]
    Maps[Google Maps / Directions]
  end

  subgraph HW[Phone Hardware]
    GPS[GPS]
    Mic[Microphone]
    Speaker[Speaker]
    Accel[Accelerometer]
    VolBtn[Volume Buttons]
  end

  %% Layout & flows
  VIU --> UMain
  GUARD --> GInterface
  UMain --> Main
  GInterface --> Firestore

  Camera --> Obj
  Camera --> Face
  Obj --> Main
  Face --> Main
  Face --> SQLite
  Main --> SQLite["saves synced embedding"]

  Main -->|"writes face embedding (register)"| Firestore
  SyncSvc -->|"reads face embeddings (sync)"| SQLite
  Firestore -->|"sync faces"| SyncSvc

  GPS --> LocationSvc
  LocationSvc -->|"writes live GPS"| Firestore
  Main -->|"reads live GPS"| LocationSvc

  Accel -->|"free-fall + impact"| Main
  Main -->|"safety prompt / countdown"| UMain
  Main -->|"send SOS"| Firestore

  VolBtn -->|"double-press -> voice"| UMain
  VolBtn -->|"triple-press (planned) -> favorite"| FavScreen

  Mic --> UMain
  UMain -->|"voice command"| Nav
  Nav --> Maps
  Maps -->|"route data"| Nav

  Main --> Tracker
  Tracker -->|"location & battery"| Firestore

  %% Notes
  classDef cloud fill:#f9f,stroke:#333,stroke-width:1px;
  class CLOUD cloud
