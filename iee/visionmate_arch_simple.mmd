flowchart LR
  VIU[Visually Impaired User]
  GUARD[Guardian]

  subgraph APP[VisionMate App]
    Camera[Camera]
    Obj[Object Detector - YOLOv8n]
    Face[Face Recognition - MobileFaceNet]
    SQLite[SQLite Embeddings]
    Main[Main Logic]
    UMain[User Main UI]
    GInterface[Guardian UI]
    Fav[Favorite Destinations]
    LocationSvc[Location Service]
    Tracker[Location Tracker]
    Sync[Firebase Sync]
    Nav[Navigation Module]
  end

  subgraph CLOUD[Cloud Services]
    Auth[Firebase Auth]
    Firestore[Firestore]
    Maps[Google Maps]
  end

  subgraph HW[Phone Hardware]
    GPS[GPS]
    Mic[Microphone]
    Speaker[Speaker]
    Accel[Accelerometer]
    VolBtn[Volume Buttons]
  end

  VIU --> UMain
  GUARD --> GInterface

  Camera --> Obj
  Camera --> Face
  Obj --> Main
  Face --> Main
  Face --> SQLite
  Sync --> SQLite
  Firestore --> Sync
  Main --> Firestore

  GPS --> LocationSvc
  LocationSvc --> Firestore
  Main --> Tracker
  Tracker --> Firestore

  Accel --> Main
  Main --> UMain
  Main --> Firestore

  VolBtn --> UMain
  VolBtn -. double-press .-> UMain
  VolBtn -. triple-press .-> Fav

  Mic --> UMain
  UMain --> Nav
  Nav --> Maps
  Maps --> Nav
